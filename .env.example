# Google OAuth (obrigatório)
GOOGLE_CLIENT_ID=seu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu-client-secret

# Banco de dados MySQL (Railway preenche automaticamente)
DATABASE_URL=mysql://user:password@host:3306/dbname

# Segredo para assinar os cookies de sessão (gere uma string aleatória longa)
JWT_SECRET=uma-string-secreta-longa-e-aleatoria

# URL pública do app (Railway preenche automaticamente ou configure manualmente)
APP_URL=https://seu-app.railway.app

# Node
NODE_ENV=production
